@model TorneosFutbolMVC.Models.Torneo

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Crear Nuevo Torneo</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Crear" method="post">
                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label">Nombre del Torneo</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej. Copa Mundial De la FIFA" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Edicion" class="form-label">Año</label>
                            <input asp-for="Edicion" class="form-control" type="number" value="@DateTime.Now.Year" />
                            <span asp-validation-for="Edicion" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Guardar Torneo</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}