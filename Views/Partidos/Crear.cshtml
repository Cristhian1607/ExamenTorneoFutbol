@model TorneosFutbolMVC.Models.Partido

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Programar Partido</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Crear" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="TorneoId" />

                        <div class="mb-3">
                            <label asp-for="FechaPartido" class="form-label">Fecha y Hora</label>
                            <input asp-for="FechaPartido" class="form-control" type="datetime-local" />
                            <span asp-validation-for="FechaPartido" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EquipoLocalId" class="form-label">Equipo Local</label>
                            <select asp-for="EquipoLocalId" class="form-select" asp-items="@(new SelectList(ViewBag.Equipos, "Id", "Nombre"))">
                                <option value="">-- Seleccione el Local --</option>
                            </select>
                            <span asp-validation-for="EquipoLocalId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EquipoVisitanteId" class="form-label">Equipo Visitante</label>
                            <select asp-for="EquipoVisitanteId" class="form-select" asp-items="@(new SelectList(ViewBag.Equipos, "Id", "Nombre"))">
                                <option value="">-- Seleccione el Visitante --</option>
                            </select>
                            <span asp-validation-for="EquipoVisitanteId" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Detalles", "Torneos", new { id = Model.TorneoId })" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Programar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>